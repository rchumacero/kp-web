---
// src/pages/index.astro
import Layout from "../layouts/Layout.astro";
import tasks from "../data/tasks.json";
import products from "../data/products.json";
import customers from "../data/customers.json";

const currentYear = new Date().getFullYear();
const yearsOfExperience = currentYear - 2012;
---

<Layout
	title="Kplian | Soluciones Tecnológicas & Enterprise Software Architecture"
	description="Kplian brinda servicios de consultoría informática de alto nivel, desarrollo de ERP modular, arquitectura de software escalable y soluciones open-source."
>
	<!-- Navigation bar (Nvidia Style) -->
	<nav class="navbar" id="navbar">
		<div class="nav-container">
			<a href="#" class="logo-link">
				<img
					src="/logo-kplian.png"
					alt="Kplian Logo"
					class="logo-img"
				/>
			</a>

			<!-- Desktop Links -->
			<div class="nav-links">
				<a href="#about" class="nav-item" data-i18n="nav.about"
					>Acerca de</a
				>
				<a href="#services" class="nav-item" data-i18n="nav.services"
					>Servicios</a
				>
				<a href="#products" class="nav-item" data-i18n="nav.products"
					>Productos</a
				>
				<a
					href="#philosophy"
					class="nav-item"
					data-i18n="nav.philosophy">Filosofía</a
				>
				<a href="#customers" class="nav-item" data-i18n="nav.customers"
					>Clientes</a
				>

				<!-- Language Selector Dropdown -->
				<div class="lang-selector" id="lang-selector">
					<button
						class="lang-btn"
						id="lang-btn"
						aria-haspopup="true"
						aria-expanded="false"
					>
						<svg
							class="w-4 h-4 globe-icon"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
							xmlns="http://www.w3.org/2000/svg"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"
							></path>
						</svg>
						<span id="current-lang-label">ES</span>
						<svg
							class="w-3 h-3 arrow-icon"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
							xmlns="http://www.w3.org/2000/svg"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2.5"
								d="M19 9l-7 7-7-7"></path>
						</svg>
					</button>
					<div class="lang-dropdown" id="lang-dropdown">
						<button class="lang-option active" data-lang="es"
							>Español (ES)</button
						>
						<button class="lang-option" data-lang="en"
							>English (EN)</button
						>
						<button class="lang-option" data-lang="pt"
							>Português (PT)</button
						>
					</div>
				</div>

				<a href="#contacto" class="btn-nav" data-i18n="nav.contact"
					>Contacto</a
				>
			</div>

			<!-- Mobile toggle -->
			<button
				class="mobile-toggle"
				id="mobile-toggle"
				aria-label="Toggle Menu"
			>
				<span></span>
				<span></span>
				<span></span>
			</button>
		</div>

		<!-- Mobile Drawer Menu -->
		<div class="mobile-menu" id="mobile-menu">
			<a href="#about" class="mobile-nav-item" data-i18n="nav.about"
				>Acerca de</a
			>
			<a href="#services" class="mobile-nav-item" data-i18n="nav.services"
				>Servicios</a
			>
			<a href="#products" class="mobile-nav-item" data-i18n="nav.products"
				>Productos</a
			>
			<a
				href="#philosophy"
				class="mobile-nav-item"
				data-i18n="nav.philosophy">Filosofía</a
			>
			<a
				href="#customers"
				class="mobile-nav-item"
				data-i18n="nav.customers">Clientes</a
			>

			<!-- Mobile Language Row -->
			<div class="mobile-lang-row">
				<button class="mobile-lang-btn active" data-lang="es">ES</button
				>
				<button class="mobile-lang-btn" data-lang="en">EN</button>
				<button class="mobile-lang-btn" data-lang="pt">PT</button>
			</div>

			<a
				href="#contacto"
				class="mobile-nav-item mobile-btn"
				data-i18n="nav.contact">Contacto</a
			>
		</div>
	</nav>

	<!-- Cinematic Hero Slider (Nvidia Style) -->
	<header class="hero-slider-section">
		<div class="slider-container">
			<!-- Slide 1 (PXP & Software Architecture) -->
			<div
				class="hero-slide active"
				id="slide-1"
				style="background-image: linear-gradient(180deg, rgba(3, 7, 18, 0.45) 0%, rgba(3, 7, 18, 0.85) 100%), url('/slide-dev.png');"
			>
				<div class="container hero-slide-content">
					<div class="badge">
						<span class="badge-dot"></span>
						<span class="badge-txt" data-i18n="hero.slide1.badge"
							>PXP FRAMEWORK & AGILE ENGINEERING</span
						>
					</div>
					<h1 class="hero-title">
						<span data-i18n="hero.slide1.title1"
							>Arquitectura de Software</span
						>
						<span
							class="gradient-text font-bold"
							data-i18n="hero.slide1.title2">Empresarial</span
						>
					</h1>
					<p class="hero-subtitle" data-i18n="hero.slide1.subtitle">
						Construimos plataformas críticas de alta disponibilidad
						y desacoplamos monolitos hacia microservicios robustos
						utilizando nuestro propio framework modular Open Source.
					</p>
					<div class="hero-actions">
						<a href="#products" class="btn-primary">
							<span data-i18n="hero.slide1.cta1">Módulos ERP</span
							>
							<svg
								class="w-4 h-4"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
								xmlns="http://www.w3.org/2000/svg"
								><path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2.5"
									d="M9 5l7 7-7 7"></path></svg
							>
						</a>
						<a
							href="#services"
							class="btn-secondary"
							data-i18n="hero.slide1.cta2">Nuestros Servicios</a
						>
					</div>
				</div>
			</div>

			<!-- Slide 2 (AI & Cloud Data Pipelines) -->
			<div
				class="hero-slide"
				id="slide-2"
				style="background-image: linear-gradient(180deg, rgba(3, 7, 18, 0.45) 0%, rgba(3, 7, 18, 0.85) 100%), url('/slide-ai.png');"
			>
				<div class="container hero-slide-content">
					<div class="badge">
						<span class="badge-dot"></span>
						<span class="badge-txt" data-i18n="hero.slide2.badge"
							>A.I. COGNITION & AUTOMATION PIPELINES</span
						>
					</div>
					<h1 class="hero-title">
						<span data-i18n="hero.slide2.title1"
							>Inteligencia Artificial y</span
						>
						<span
							class="cyan-blue-gradient font-bold"
							data-i18n="hero.slide2.title2">Flujos de Datos</span
						>
					</h1>
					<p class="hero-subtitle" data-i18n="hero.slide2.subtitle">
						Automatizamos la toma de decisiones críticas
						corporativas mediante algoritmos predictivos, análisis
						de riesgos y procesamiento inteligente de información
						empresarial.
					</p>
					<div class="hero-actions">
						<a href="#services" class="btn-primary">
							<span data-i18n="hero.slide2.cta1"
								>Inteligencia de Negocios</span
							>
							<svg
								class="w-4 h-4"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
								xmlns="http://www.w3.org/2000/svg"
								><path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2.5"
									d="M9 5l7 7-7 7"></path></svg
							>
						</a>
						<a
							href="#customers"
							class="btn-secondary"
							data-i18n="hero.slide2.cta2">Casos de Éxito</a
						>
					</div>
				</div>
			</div>
		</div>

		<!-- Slider controls -->
		<button
			class="slider-arrow prev-arrow"
			id="prev-arrow"
			aria-label="Previous Slide"
		>
			<svg
				fill="none"
				stroke="currentColor"
				viewBox="0 0 24 24"
				xmlns="http://www.w3.org/2000/svg"
				><path
					stroke-linecap="round"
					stroke-linejoin="round"
					stroke-width="2.5"
					d="M15 19l-7-7 7-7"></path></svg
			>
		</button>
		<button
			class="slider-arrow next-arrow"
			id="next-arrow"
			aria-label="Next Slide"
		>
			<svg
				fill="none"
				stroke="currentColor"
				viewBox="0 0 24 24"
				xmlns="http://www.w3.org/2000/svg"
				><path
					stroke-linecap="round"
					stroke-linejoin="round"
					stroke-width="2.5"
					d="M9 5l7 7-7 7"></path></svg
			>
		</button>

		<!-- Slide Indicators -->
		<div class="slider-indicators">
			<span class="indicator active" data-slide="0"></span>
			<span class="indicator" data-slide="1"></span>
		</div>
	</header>

	<!-- Metrics / Stats Section (Nvidia Specs Style) -->
	<section class="stats-section">
		<div class="container">
			<div class="stats-grid">
				<div class="stat-card">
					<span class="stat-label" data-i18n="stats.commits.label"
						>CÓDIGO FUENTE</span
					>
					<span class="stat-number cyan-blue-gradient">8,858+</span>
					<span class="stat-desc" data-i18n="stats.commits.desc"
						>Commits activos en plataformas</span
					>
				</div>
				<div class="stat-card">
					<span class="stat-label" data-i18n="stats.engineers.label"
						>INGENIERÍA</span
					>
					<span class="stat-number cyan-blue-gradient">25+</span>
					<span class="stat-desc" data-i18n="stats.engineers.desc"
						>Colaboradores especializados</span
					>
				</div>
				<div class="stat-card">
					<span class="stat-label" data-i18n="stats.experience.label"
						>EXPERIENCIA</span
					>
					<span class="stat-number cyan-blue-gradient">{yearsOfExperience}+</span>
					<span class="stat-desc" data-i18n="stats.experience.desc"
						>Años liderando el mercado</span
					>
				</div>
				<div class="stat-card">
					<span class="stat-label" data-i18n="stats.coffee.label"
						>ENERGÍA</span
					>
					<span class="stat-number cyan-blue-gradient">5,000+</span>
					<span class="stat-desc" data-i18n="stats.coffee.desc"
						>Tazas de café consumidas</span
					>
				</div>
			</div>
		</div>
	</section>

	<!-- About Section -->
	<section id="about" class="about-section">
		<div class="container">
			<div class="about-grid">
				<div class="about-info">
					<span class="section-tag" data-i18n="about.tag"
						>Sobre Nosotros</span
					>
					<h2 class="section-title" data-i18n="about.title">
						Soluciones informáticas de alto rendimiento
					</h2>
					<p class="section-subtitle" data-i18n="about.subtitle">
						Kplian brinda servicios de consultoría especializada
						para establecer los pilares tecnológicos que sustentan
						el crecimiento de nuestros clientes y el progreso
						tecnológico corporativo.
					</p>

					<div class="about-bullets">
						<div class="bullet-item">
							<div class="bullet-icon">
								<svg
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
									xmlns="http://www.w3.org/2000/svg"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
									></path>
								</svg>
							</div>
							<div class="bullet-text">
								<h3 data-i18n="about.bullet1.title">
									Especialización en Open Source
								</h3>
								<p data-i18n="about.bullet1.desc">
									Ofrecemos productos de la más alta calidad
									optimizando costos al evitar licencias
									propietarias restrictivas y gastos ocultos.
								</p>
							</div>
						</div>
						<div class="bullet-item">
							<div class="bullet-icon">
								<svg
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
									xmlns="http://www.w3.org/2000/svg"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 9.172V5L8 4z"
									></path>
								</svg>
							</div>
							<div class="bullet-text">
								<h3 data-i18n="about.bullet2.title">
									Tecnología de Vanguardia
								</h3>
								<p data-i18n="about.bullet2.desc">
									Desarrollamos soluciones personalizadas
									utilizando metodologías y lenguajes
									avanzados adaptados a tu negocio.
								</p>
							</div>
						</div>
					</div>
				</div>

				<div class="about-skills">
					<div class="skills-card glass-card">
						<h3 class="skills-title" data-i18n="about.skills.title">
							Capacidades Técnicas
						</h3>

						<div class="skill-bar-wrap">
							<div class="skill-info">
								<span data-i18n="about.skills.skill1"
									>Desarrollo de Software</span
								>
								<span>94%</span>
							</div>
							<div class="skill-bar">
								<div class="skill-progress" style="width: 93%;">
								</div>
							</div>
						</div>

						<div class="skill-bar-wrap">
							<div class="skill-info">
								<span data-i18n="about.skills.skill2"
									>Centrales Telefónicas (VoIP)</span
								>
								<span>92%</span>
							</div>
							<div class="skill-bar">
								<div class="skill-progress" style="width: 92%;">
								</div>
							</div>
						</div>

						<div class="skill-bar-wrap">
							<div class="skill-info">
								<span data-i18n="about.skills.skill3"
									>Arquitectura Cloud & Mobile</span
								>
								<span>82%</span>
							</div>
							<div class="skill-bar">
								<div class="skill-progress" style="width: 82%;">
								</div>
							</div>
						</div>

						<div class="skill-bar-wrap">
							<div class="skill-info">
								<span data-i18n="about.skills.skill4"
									>Diseño Web Premium</span
								>
								<span>78%</span>
							</div>
							<div class="skill-bar">
								<div class="skill-progress" style="width: 78%;">
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Services Section -->
	<section id="services" class="services-section">
		<div class="container">
			<div class="section-title-wrap">
				<span class="section-tag" data-i18n="services.tag"
					>Servicios Profesionales</span
				>
				<h2 class="section-title" data-i18n="services.title">
					¿Qué es lo que hacemos?
				</h2>
				<p class="section-subtitle" data-i18n="services.subtitle">
					Acompañamos a su organización con un portafolio completo de
					consultoría de TI y software personalizado.
				</p>
			</div>

			<div class="services-grid">
				{
					tasks.map((task) => (
						<div class="service-card glow-card">
							<div class="service-icon-wrap">
								<svg
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
									xmlns="http://www.w3.org/2000/svg"
									set:html={task.icon}
								/>
							</div>
							<h3 data-i18n={`${task.i18nKey}.title`}>
								{task.defaultTitle}
							</h3>
							<p data-i18n={`${task.i18nKey}.desc`}>
								{task.defaultDesc}
							</p>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<!-- Products Section -->
	<section id="products" class="products-section">
		<div class="container">
			<div class="section-title-wrap">
				<span class="section-tag" data-i18n="products.tag"
					>Ecosistema Tecnológico</span
				>
				<h2 class="section-title" data-i18n="products.title">
					Nuestros Productos
				</h2>
				<p class="section-subtitle" data-i18n="products.subtitle">
					Arquitectura modular de software y frameworks de desarrollo
					ágil creados internamente.
				</p>
			</div>

			<div class="products-grid">
				<!-- Main Product: Framework PXP -->
				<div class="product-featured-card glass-card">
					<div
						class="featured-badge"
						data-i18n="products.featured.badge"
					>
						FLAGSHIP FRAMEWORK
					</div>
					<div class="featured-content">
						<h3 data-i18n="products.featured.title">
							Framework PXP
						</h3>
						<p
							class="featured-desc"
							data-i18n="products.featured.desc"
						>
							Nuestro framework open-source líder diseñado para el
							desarrollo rápido e integrado de aplicaciones web y
							plataformas corporativas críticas. Basado en
							arquitecturas limpias, modulares y optimizado para
							bases de datos relacionales como PostgreSQL.
						</p>
						<div class="featured-tags">
							<span>PostgreSQL</span>
							<span>PHP / Node</span>
							<span>JavaScript</span>
							<span>Modular Workflows</span>
						</div>
						<a
							href="https://github.com/kplian"
							target="_blank"
							rel="noopener noreferrer"
							class="btn-primary"
						>
							<svg
								class="w-5 h-5"
								fill="currentColor"
								viewBox="0 0 24 24"
								xmlns="http://www.w3.org/2000/svg"
								><path
									d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
								></path></svg
							>
							<span data-i18n="products.featured.cta"
								>Ver en GitHub</span
							>
						</a>
					</div>
				</div>

				<!-- Grid of ERP modules -->
				<div class="modules-subgrid">
					{
						products.map((product) => (
							<div class="module-card glass-card">
								<h4 data-i18n={`${product.i18nKey}.title`}>
									{product.defaultTitle}
								</h4>
								<p data-i18n={`${product.i18nKey}.desc`}>
									{product.defaultDesc}
								</p>
							</div>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<!-- Philosophy Section (Nvidia Quote Block Style) -->
	<section id="philosophy" class="philosophy-section">
		<div class="container">
			<div class="philosophy-wrapper">
				<div class="quote-icon">“</div>
				<div class="quote-slider">
					<div class="quote-slide active">
						<blockquote data-i18n="philosophy.quote">
							Escuchamos sus necesidades, las estudiamos y
							planteamos una solución. Desarrollamos el software a
							la medida de su empresa y le acompañamos plenamente
							en el proceso de implantación corporativo.
						</blockquote>
						<cite data-i18n="philosophy.author"
							>— Filosofía Fundamental KPLIAN</cite
						>
					</div>
				</div>

				<div class="philosophy-pillars">
					<div class="pillar-card">
						<h3 data-i18n="philosophy.pillar1.title">
							Singularidad
						</h3>
						<p data-i18n="philosophy.pillar1.desc">
							Cada empresa es única y necesita soluciones de
							software que respondan con precisión a su propia
							identidad operativa.
						</p>
					</div>
					<div class="pillar-card">
						<h3 data-i18n="philosophy.pillar2.title">
							Creación de Valor
