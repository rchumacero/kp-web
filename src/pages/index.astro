---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Kplian | Soluciones Tecnológicas & Enterprise Software Architecture"
  description="Kplian brinda servicios de consultoría informática de alto nivel, desarrollo de ERP modular, arquitectura de software escalable y soluciones open-source."
>
  <!-- Navigation bar (Nvidia Style) -->
  <nav class="navbar" id="navbar">
    <div class="nav-container">
      <a href="#" class="logo-link">
        <img src="/logo-kplian.png" alt="Kplian Logo" class="logo-img" />
      </a>

      <!-- Desktop Links -->
      <div class="nav-links">
        <a href="#about" class="nav-item">Acerca de</a>
        <a href="#services" class="nav-item">Servicios</a>
        <a href="#products" class="nav-item">Productos</a>
        <a href="#philosophy" class="nav-item">Filosofía</a>
        <a href="#customers" class="nav-item">Clientes</a>
        <a href="#contacto" class="btn-nav">Contacto</a>
      </div>

      <!-- Mobile toggle -->
      <button class="mobile-toggle" id="mobile-toggle" aria-label="Toggle Menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>

    <!-- Mobile Drawer Menu -->
    <div class="mobile-menu" id="mobile-menu">
      <a href="#about" class="mobile-nav-item">Acerca de</a>
      <a href="#services" class="mobile-nav-item">Servicios</a>
      <a href="#products" class="mobile-nav-item">Productos</a>
      <a href="#philosophy" class="mobile-nav-item">Filosofía</a>
      <a href="#customers" class="mobile-nav-item">Clientes</a>
      <a href="#contacto" class="mobile-nav-item mobile-btn">Contacto</a>
    </div>
  </nav>

  <!-- Cinematic Hero Slider (Nvidia Style) -->
  <header class="hero-slider-section">
    <div class="slider-container">
      <!-- Slide 1 (PXP & Software Architecture) -->
      <div class="hero-slide active" id="slide-1" style="background-image: linear-gradient(180deg, rgba(3, 7, 18, 0.45) 0%, rgba(3, 7, 18, 0.85) 100%), url('/slide-dev.png');">
        <div class="container hero-slide-content">
          <div class="badge">
            <span class="badge-dot"></span>
            <span class="badge-txt">PXP FRAMEWORK & AGILE ENGINEERING</span>
          </div>
          <h1 class="hero-title">
            Arquitectura de Software <span class="gradient-text font-bold">Empresarial</span>
          </h1>
          <p class="hero-subtitle">
            Construimos plataformas críticas de alta disponibilidad y desacoplamos monolitos hacia microservicios robustos utilizando nuestro propio framework modular Open Source.
          </p>
          <div class="hero-actions">
            <a href="#products" class="btn-primary">
              Módulos ERP
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path></svg>
            </a>
            <a href="#services" class="btn-secondary">Nuestros Servicios</a>
          </div>
        </div>
      </div>

      <!-- Slide 2 (AI & Cloud Data Pipelines) -->
      <div class="hero-slide" id="slide-2" style="background-image: linear-gradient(180deg, rgba(3, 7, 18, 0.45) 0%, rgba(3, 7, 18, 0.85) 100%), url('/slide-ai.png');">
        <div class="container hero-slide-content">
          <div class="badge">
            <span class="badge-dot"></span>
            <span class="badge-txt">A.I. COGNITION & AUTOMATION PIPELINES</span>
          </div>
          <h1 class="hero-title">
            Inteligencia Artificial y <span class="cyan-blue-gradient font-bold">Flujos de Datos</span>
          </h1>
          <p class="hero-subtitle">
            Automatizamos la toma de decisiones críticas corporativas mediante algoritmos predictivos, análisis de riesgos y procesamiento inteligente de información empresarial.
          </p>
          <div class="hero-actions">
            <a href="#services" class="btn-primary">
              Inteligencia de Negocios
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path></svg>
            </a>
            <a href="#customers" class="btn-secondary">Casos de Éxito</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Slider controls -->
    <button class="slider-arrow prev-arrow" id="prev-arrow" aria-label="Previous Slide">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"></path></svg>
    </button>
    <button class="slider-arrow next-arrow" id="next-arrow" aria-label="Next Slide">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path></svg>
    </button>

    <!-- Slide Indicators -->
    <div class="slider-indicators">
      <span class="indicator active" data-slide="0"></span>
      <span class="indicator" data-slide="1"></span>
    </div>
  </header>

  <!-- Metrics / Stats Section (Nvidia Specs Style) -->
  <section class="stats-section">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-card">
          <span class="stat-label">CÓDIGO FUENTE</span>
          <span class="stat-number cyan-blue-gradient">8,858+</span>
          <span class="stat-desc">Commits activos en plataformas</span>
        </div>
        <div class="stat-card">
          <span class="stat-label">INGENIERÍA</span>
          <span class="stat-number cyan-blue-gradient">25+</span>
          <span class="stat-desc">Colaboradores especializados</span>
        </div>
        <div class="stat-card">
          <span class="stat-label">EXPERIENCIA</span>
          <span class="stat-number cyan-blue-gradient">11+</span>
          <span class="stat-desc">Años liderando el mercado</span>
        </div>
        <div class="stat-card">
          <span class="stat-label">ENERGÍA</span>
          <span class="stat-number cyan-blue-gradient">5,000+</span>
          <span class="stat-desc">Tazas de café consumidas</span>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="about-section">
    <div class="container">
      <div class="about-grid">
        <div class="about-info">
          <span class="section-tag">Sobre Nosotros</span>
          <h2 class="section-title">Soluciones informáticas de alto rendimiento</h2>
          <p class="section-subtitle">
            Kplian brinda servicios de consultoría especializada para establecer los pilares tecnológicos que sustentan el crecimiento de nuestros clientes y el progreso tecnológico corporativo.
          </p>
          
          <div class="about-bullets">
            <div class="bullet-item">
              <div class="bullet-icon">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              </div>
              <div class="bullet-text">
                <h3>Especialización en Open Source</h3>
                <p>Ofrecemos productos de la más alta calidad optimizando costos al evitar licencias propietarias restrictivas y gastos ocultos.</p>
              </div>
            </div>
            <div class="bullet-item">
              <div class="bullet-icon">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 9.172V5L8 4z"></path></svg>
              </div>
              <div class="bullet-text">
                <h3>Tecnología de Vanguardia</h3>
                <p>Desarrollamos soluciones personalizadas utilizando metodologías y lenguajes avanzados adaptados a tu negocio.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="about-skills">
          <div class="skills-card glass-card">
            <h3 class="skills-title">Capacidades Técnicas</h3>
            
            <div class="skill-bar-wrap">
              <div class="skill-info">
                <span>Desarrollo de Software</span>
                <span>93%</span>
              </div>
              <div class="skill-bar">
                <div class="skill-progress" style="width: 93%;"></div>
              </div>
            </div>

            <div class="skill-bar-wrap">
              <div class="skill-info">
                <span>Centrales Telefónicas (VoIP)</span>
                <span>92%</span>
              </div>
              <div class="skill-bar">
                <div class="skill-progress" style="width: 92%;"></div>
              </div>
            </div>

            <div class="skill-bar-wrap">
              <div class="skill-info">
                <span>Arquitectura Cloud & Mobile</span>
                <span>82%</span>
              </div>
              <div class="skill-bar">
                <div class="skill-progress" style="width: 82%;"></div>
              </div>
            </div>

            <div class="skill-bar-wrap">
              <div class="skill-info">
                <span>Diseño Web Premium</span>
                <span>78%</span>
              </div>
              <div class="skill-bar">
                <div class="skill-progress" style="width: 78%;"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="services-section">
    <div class="container">
      <div class="section-title-wrap">
        <span class="section-tag">Servicios Profesionales</span>
        <h2 class="section-title">¿Qué es lo que hacemos?</h2>
        <p class="section-subtitle">Acompañamos a su organización con un portafolio completo de consultoría de TI y software personalizado.</p>
      </div>

      <div class="services-grid">
        <!-- Service 1 -->
        <div class="service-card glow-card">
          <div class="service-icon-wrap">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
          </div>
          <h3>Enterprise Resource Planning (ERP)</h3>
          <p>
            Sabemos que el software debe adaptarse a las empresas y no al revés. Contamos con amplia experiencia en el desarrollo e implantación de módulos ERP integrados para grandes corporaciones.
          </p>
        </div>

        <!-- Service 2 -->
        <div class="service-card glow-card">
          <div class="service-icon-wrap">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
          </div>
          <h3>Diseño y Desarrollo de Software</h3>
          <p>
            Necesidades específicas exigen desarrollo a la medida. Contamos con procesos ágiles e innovadores ejecutados por un equipo de ingenieros senior enfocado en altos estándares de calidad.
          </p>
        </div>

        <!-- Service 3 -->
        <div class="service-card glow-card">
          <div class="service-icon-wrap">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
          </div>
          <h3>Diseño Web Responsivo</h3>
          <p>
            Creamos interfaces interactivas fluidas que funcionan en computadoras y dispositivos móviles. Con código nativo limpio, garantizando velocidad y rendimiento estelar.
          </p>
        </div>

        <!-- Service 4 -->
        <div class="service-card glow-card">
          <div class="service-icon-wrap">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
          </div>
          <h3>Inteligencia de Negocios (BI)</h3>
          <p>
            Facilitamos la toma de decisiones precisas y rápidas. Proveemos servicios de BI bajo el principio de "información correcta de manera oportuna, transparente y clara".
          </p>
        </div>

        <!-- Service 5 -->
        <div class="service-card glow-card">
          <div class="service-icon-wrap">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
          </div>
          <h3>Seguridad de Información</h3>
          <p>
            Análisis de riesgos y seguridad informática empresarial integral. Le acompañamos en la identificación de amenazas, vulnerabilidades, mitigación y despliegue seguro.
          </p>
        </div>

        <!-- Service 6 -->
        <div class="service-card glow-card">
          <div class="service-icon-wrap">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
          </div>
          <h3>Centrales Telefónicas VoIP</h3>
          <p>
            Planificamos, provisionamos e implementamos soluciones corporativas de Comunicación Unificada y plataformas VoIP robustas adaptadas al tamaño y exigencia de su negocio.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Products Section -->
  <section id="products" class="products-section">
    <div class="container">
      <div class="section-title-wrap">
        <span class="section-tag">Ecosistema Tecnológico</span>
        <h2 class="section-title">Nuestros Productos</h2>
        <p class="section-subtitle">Arquitectura modular de software y frameworks de desarrollo ágil creados internamente.</p>
      </div>

      <div class="products-grid">
        <!-- Main Product: Framework PXP -->
        <div class="product-featured-card glass-card">
          <div class="featured-badge">FLAGSHIP FRAMEWORK</div>
          <div class="featured-content">
            <h3>Framework PXP</h3>
            <p class="featured-desc">
              Nuestro framework open-source líder diseñado para el desarrollo rápido e integrado de aplicaciones web y plataformas corporativas críticas. Basado en arquitecturas limpias, modulares y optimizado para bases de datos relacionales como PostgreSQL.
            </p>
            <div class="featured-tags">
              <span>PostgreSQL</span>
              <span>PHP / Node</span>
              <span>JavaScript</span>
              <span>Modular Workflows</span>
            </div>
            <a href="https://github.com/kplian" target="_blank" rel="noopener noreferrer" class="btn-primary">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              Ver en GitHub
            </a>
          </div>
        </div>

        <!-- Grid of ERP modules -->
        <div class="modules-subgrid">
          <div class="module-card glass-card">
            <h4>Facturación Computarizada</h4>
            <p>Módulo de emisión fiscal robusto, homologado con la normativa local vigente.</p>
          </div>
          <div class="module-card glass-card">
            <h4>Gestión de Colas</h4>
            <p>Monitoreo, distribución y optimización de la atención al cliente en tiempo real.</p>
          </div>
          <div class="module-card glass-card">
            <h4>Contabilidad y Presupuestos</h4>
            <p>Estados financieros integrados, control presupuestario y balances en vivo.</p>
          </div>
          <div class="module-card glass-card">
            <h4>Activos Fijos y Almacenes</h4>
            <p>Seguimiento de valorización, depreciación y control estricto de inventarios.</p>
          </div>
          <div class="module-card glass-card">
            <h4>Planillas & Recursos Humanos</h4>
            <p>Cálculo exacto de salarios, planillas de aportes fiscales e historial laboral.</p>
          </div>
          <div class="module-card glass-card">
            <h4>Gestión Documental (Core)</h4>
            <p>Estructuración de flujos documentales, firmas digitales e histórico corporativo.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Philosophy Section (Nvidia Quote Block Style) -->
  <section id="philosophy" class="philosophy-section">
    <div class="container">
      <div class="philosophy-wrapper">
        <div class="quote-icon">“</div>
        <div class="quote-slider">
          <div class="quote-slide active">
            <blockquote>
              Escuchamos sus necesidades, las estudiamos y planteamos una solución. Desarrollamos el software a la medida de su empresa y le acompañamos plenamente en el proceso de implantación corporativo.
            </blockquote>
            <cite>— Filosofía Fundamental KPLIAN</cite>
          </div>
        </div>
        
        <div class="philosophy-pillars">
          <div class="pillar-card">
            <h3>Singularidad</h3>
            <p>Cada empresa es única y necesita soluciones de software que respondan con precisión a su propia identidad operativa.</p>
          </div>
          <div class="pillar-card">
            <h3>Creación de Valor</h3>
            <p>Creemos que la tecnología de información debe ser el catalizador principal de la eficiencia y la rentabilidad empresarial.</p>
          </div>
          <div class="pillar-card">
            <h3>Adaptabilidad</h3>
            <p>El software es el que debe amoldarse y optimizar los procesos de la empresa, nunca a la inversa.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Customers Section -->
  <section id="customers" class="customers-section">
    <div class="container">
      <div class="section-title-wrap text-center">
        <span class="section-tag">Garantía Corporativa</span>
        <h2 class="section-title">Clientes de Confianza</h2>
        <p class="section-subtitle mx-auto">Sistemas críticos de información implantados con éxito en importantes corporaciones del país.</p>
      </div>

      <div class="customers-grid">
        <!-- Client 1 -->
        <div class="client-card glass-card">
          <div class="client-header">
            <img src="/clientes/boa.jpg" alt="BOA Logo" class="client-logo-img" />
            <h4>Boliviana de Aviación</h4>
          </div>
          <p class="client-desc">
            Desarrollo e Implementación del ERP-BOA con los módulos de Contabilidad, Presupuestos, Almacenes, Recursos Humanos, Activos Fijos y Tesorería.
          </p>
          <span class="client-tech">PXP Framework • PostgreSQL • JavaScript</span>
        </div>

        <!-- Client 2 -->
        <div class="client-card glass-card">
          <div class="client-header">
            <img src="/clientes/comibol.png" alt="COMIBOL Logo" class="client-logo-img" />
            <h4>Corporación Minera de Bolivia</h4>
          </div>
          <p class="client-desc">
            Implementación y adecuación de módulos de Almacenes, Recursos Humanos y Activos Fijos del ERP centralizado junto a facturación a medida.
          </p>
          <span class="client-tech">PXP Framework • PostgreSQL • JavaScript</span>
        </div>

        <!-- Client 3 -->
        <div class="client-card glass-card">
          <div class="client-header">
            <img src="/clientes/logistica.jpg" alt="YPFB Logística Logo" class="client-logo-img" />
            <h4>YPFB Logística S.A.</h4>
          </div>
          <p class="client-desc">
            Diseño e implementación especializada del sistema de control y Mantenimiento Industrial crítico para la cadena logística de hidrocarburos.
          </p>
          <span class="client-tech">PXP Framework • PostgreSQL • PHP</span>
        </div>

        <!-- Client 4 -->
        <div class="client-card glass-card">
          <div class="client-header">
            <img src="/clientes/etr.png" alt="ENDE Transmisión Logo" class="client-logo-img" />
            <h4>ENDE Transmisión</h4>
          </div>
          <p class="client-desc">
            Implementación completa del Sistema Administrativo Financiero ERP-BOA para el control de operaciones de la red eléctrica nacional.
          </p>
          <span class="client-tech">PXP Framework • PostgreSQL • PHP</span>
        </div>

        <!-- Client 5 -->
        <div class="client-card glass-card">
          <div class="client-header">
            <img src="/clientes/ofep.jpg" alt="OFEP Logo" class="client-logo-img" />
            <h4>OFEP</h4>
          </div>
          <p class="client-desc">
            Servicio de formación técnica y consultoría avanzada en módulos integrales del ERP PXP (Seguridad, Flujos de Trabajo, Compras).
          </p>
          <span class="client-tech">PXP Framework • HTML5 • jQuery</span>
        </div>

        <!-- Client 6 -->
        <div class="client-card glass-card">
          <div class="client-header">
