---
// src/layouts/Layout.astro
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "Kplian - Enterprise Software Architecture & Cloud Solutions",
	description = "Kplian brinda servicios de consultoría informática de alto nivel, desarrollo de ERP modular, arquitectura de software escalable y soluciones open-source."
} = Astro.props;
---
<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<!-- Cybernetic background and grids -->
		<div class="tech-bg">
			<div class="tech-grid"></div>
			<div class="glow-orb-1"></div>
			<div class="glow-orb-2"></div>
		</div>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
